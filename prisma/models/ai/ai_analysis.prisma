// prisma/models/ai/ai_analysis.prisma
// تحليلات الذكاء الاصطناعي والتنبؤات

model AIAnalysis {
  @@schema("ai")
  id              String       @id @default(cuid())
  studentId       String
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type            AnalysisType
  data            Json
  summary         String?      @db.Text
  recommendations String[]
  createdAt       DateTime     @default(now())
  expiresAt       DateTime?

  @@index([studentId, type])
  @@map("ai_analysis")
}

model AIPrediction {
  @@schema("ai")
  id          String        @id @default(cuid())
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        PredictionType
  value       Float
  confidence  Float
  factors     Json?
  createdAt   DateTime      @default(now())
  validatedAt DateTime?
  isAccurate  Boolean?

  @@index([studentId, type])
  @@map("ai_predictions")
}

model AIGrading {
  @@schema("ai")
  id           String    @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  score        Float
  feedback     String    @db.Text
  rubricScores Json?
  model        String
  confidence   Float
  createdAt    DateTime  @default(now())

  @@unique([submissionId])
  @@map("ai_grading")
}

enum AnalysisType {
  PERFORMANCE
  BEHAVIOR
  ENGAGEMENT
  RISK
  STRENGTH_WEAKNESS
}

enum PredictionType {
  GRADE
  COMPLETION
  CHURN
  SUCCESS
}


