// prisma/models/assessment/submissions.prisma
// إجابات الطلاب والتصحيح

model Submission {
  @@schema("assessment")
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId  String?
  assignment    Assignment? @relation(fields: [assignmentId], references: [id])
  quizAttemptId String?
  quizAttempt   QuizAttempt? @relation(fields: [quizAttemptId], references: [id])
  score         Float?
  maxScore      Float
  percentage    Float?
  passed        Boolean?
  feedback      String?   @db.Text
  feedbackAi    String?   @db.Text
  timeTaken     Int?
  attemptNumber Int       @default(1)
  isGraded      Boolean   @default(false)
  isLate        Boolean   @default(false)
  submittedAt   DateTime  @default(now())
  gradedAt      DateTime?
  gradedBy      String?

  answers        QuestionAnswer[]
  gradingRecords GradingRecord[]

  @@index([studentId, assignmentId])
  @@map("submissions")
}

model QuizAttempt {
  @@schema("assessment")
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score         Float
  maxScore      Float
  percentage    Float
  passed        Boolean?
  timeTaken     Int?
  attemptNumber Int       @default(1)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  answers     QuestionAnswer[]
  submissions Submission[]

  @@index([studentId, quizId])
  @@map("quiz_attempts")
}

model QuestionAnswer {
  @@schema("assessment")
  id            String    @id @default(cuid())
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id])
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answer        String?   @db.Text
  isCorrect     Boolean?
  pointsEarned  Float?
  feedback      String?   @db.Text
  quizAttemptId String?
  quizAttempt   QuizAttempt? @relation(fields: [quizAttemptId], references: [id])
  submissionId  String?
  submission    Submission? @relation(fields: [submissionId], references: [id])
  createdAt     DateTime  @default(now())

  @@index([studentId, questionId])
  @@map("question_answers")
}

model OpenEndedAnswer {
  @@schema("assessment")
  id              String    @id @default(cuid())
  questionId      String
  question        Question  @relation(fields: [questionId], references: [id])
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answer          String    @db.Text
  aiGrading       Json?
  teacherGrading  Json?
  finalGrade      Float?
  feedback        String?   @db.Text
  isAIGraded      Boolean   @default(false)
  isTeacherGraded Boolean   @default(false)
  submittedAt     DateTime  @default(now())
  gradedAt        DateTime?

  @@map("open_ended_answers")
}

model GradingRubric {
  @@schema("assessment")
  id           String    @id @default(cuid())
  name         String
  description  String?   @db.Text
  criteria     Json
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  quizId       String?
  quiz         Quiz?     @relation(fields: [quizId], references: [id])
  isDefault    Boolean   @default(false)
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  gradingRecords GradingRecord[]

  @@map("grading_rubrics")
}

model GradingRecord {
  @@schema("assessment")
  id           String    @id @default(cuid())
  rubricId     String
  rubric       GradingRubric @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  scores       Json
  totalScore   Float
  feedback     String?   @db.Text
  gradedBy     String?
  gradedAt     DateTime  @default(now())

  @@unique([rubricId, submissionId])
  @@map("grading_records")
}


