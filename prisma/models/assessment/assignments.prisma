// prisma/models/assessment/assignments.prisma
// التمارين والاختبارات

model Assignment {
  @@schema("assessment")
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  type         AssignmentType @default(PRACTICE)
  difficulty   Difficulty     @default(MEDIUM)
  points       Int            @default(10)
  timeLimit    Int?
  passingScore Int?
  isPublished  Boolean        @default(false)
  isFree       Boolean        @default(false)
  dueDate      DateTime?
  maxAttempts  Int?           @default(1)
  teacherId    String?
  teacher      Teacher?       @relation(fields: [teacherId], references: [id])
  subjectId    String?
  subject      Subject?       @relation(fields: [subjectId], references: [id])
  lessonId     String?
  lesson       Lesson?        @relation(fields: [lessonId], references: [id])
  chapterId    String?
  chapter      Chapter?       @relation(fields: [chapterId], references: [id])
  classGroupId String?
  classGroup   ClassGroup?    @relation(fields: [classGroupId], references: [id])

  questions     Question[]
  submissions   Submission[]
  gradingRubric GradingRubric?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([teacherId, subjectId])
  @@map("assignments")
}

model Quiz {
  @@schema("assessment")
  id               String    @id @default(cuid())
  title            String
  description      String?   @db.Text
  type             QuizType  @default(PRACTICE)
  difficulty       Difficulty @default(MEDIUM)
  timeLimit        Int?
  passingScore     Int?
  isPublished      Boolean   @default(false)
  isFree           Boolean   @default(false)
  isTimed          Boolean   @default(false)
  shuffleQuestions Boolean   @default(false)
  shuffleOptions   Boolean   @default(false)
  showAnswers      Boolean   @default(true)
  points           Int       @default(10)
  maxAttempts      Int?      @default(1)
  teacherId        String?
  teacher          Teacher?  @relation(fields: [teacherId], references: [id])
  subjectId        String?
  subject          Subject?  @relation(fields: [subjectId], references: [id])
  lessonId         String?
  lesson           Lesson?   @relation(fields: [lessonId], references: [id])
  chapterId        String?
  chapter          Chapter?  @relation(fields: [chapterId], references: [id])
  classGroupId     String?
  classGroup       ClassGroup? @relation(fields: [classGroupId], references: [id])

  questions Question[]
  attempts  QuizAttempt[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([teacherId, subjectId])
  @@map("quizzes")
}

enum AssignmentType {
  PRACTICE
  QUIZ
  EXAM
  CHALLENGE
  PROJECT
}

enum QuizType {
  PRACTICE
  PLACEMENT_TEST
  CHAPTER_TEST
  FINAL_EXAM
  DIAGNOSTIC
  ADAPTIVE
}


