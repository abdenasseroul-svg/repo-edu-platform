// prisma/models/security/proctoring.prisma
// مراقبة الامتحانات عن بعد

model ExamSession {
  @@schema("security")
  id          String             @id @default(cuid())
  studentId   String
  student     Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  examId      String
  examType    String
  status      ExamSessionStatus  @default(PENDING)
  startTime   DateTime
  endTime     DateTime?
  duration    Int
  isProctored Boolean            @default(true)
  deviceId    String?
  ipAddress   String?
  userAgent   String?

  events   ProctorEvent[]
  captures ScreenCapture[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([studentId, examId])
  @@map("exam_sessions")
}

model ProctorEvent {
  @@schema("security")
  id          String           @id @default(cuid())
  sessionId   String
  session     ExamSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type        ProctorEventType
  severity    Int              @default(1)
  description String?          @db.Text
  data        Json?
  timestamp   DateTime         @default(now())

  @@index([sessionId, type])
  @@map("proctor_events")
}

model ScreenCapture {
  @@schema("security")
  id        String    @id @default(cuid())
  sessionId String
  session   ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  imageUrl  String
  timestamp DateTime  @default(now())
  metadata  Json?

  @@map("screen_captures")
}

enum ExamSessionStatus {
  PENDING
  STARTED
  COMPLETED
  ABANDONED
  VIOLATION
}

enum ProctorEventType {
  FACE_MISSING
  MULTIPLE_FACES
  OBJECT_DETECTED
  TAB_SWITCH
  SCREEN_SHARE
  AUDIO_CHANGE
  SUSPICIOUS_MOTION
  TIMEOUT
}


