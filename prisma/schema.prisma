// prisma/schema.prisma - المنصة التعليمية للثانوي الجزائري
// الملف الرئيسي الشامل لجميع النماذج

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
  output          = "../backend/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  STUDENT
  TEACHER
  ADMIN
  SUPER_ADMIN
}

enum Level {
  ONE_AS
  TWO_AS
  THREE_AS
}

enum Stream {
  SCIENCE
  LITERATURE
  TECHNICAL_MATH
  MATH
  FOREIGN_LANGUAGES
  MANAGEMENT
}

enum ResourceType {
  PDF
  VIDEO
  AUDIO
  IMAGE
  PRESENTATION
  SPREADSHEET
  OTHER
}

enum QuestionType {
  MULTIPLE_CHOICE
  SINGLE_CHOICE
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  OPEN_ENDED
  PROGRAMMING
  MATH
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  CHALLENGE
}

enum AssignmentType {
  PRACTICE
  QUIZ
  EXAM
  CHALLENGE
  PROJECT
}

enum QuizType {
  PRACTICE
  PLACEMENT_TEST
  CHAPTER_TEST
  FINAL_EXAM
  DIAGNOSTIC
  ADAPTIVE
}

enum AIMessageRole {
  SYSTEM
  USER
  ASSISTANT
  FUNCTION
}

enum OCRStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RecommendationType {
  LESSON
  QUIZ
  ASSIGNMENT
  RESOURCE
  PRACTICE
  VIDEO
  FLASHCARD
}

enum LearningPathType {
  PERSONALIZED
  STANDARD
  ACCELERATED
  REMEDIAL
}

enum LearningPathStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum AnalysisType {
  PERFORMANCE
  BEHAVIOR
  ENGAGEMENT
  RISK
  STRENGTH_WEAKNESS
}

enum PredictionType {
  GRADE
  COMPLETION
  CHURN
  SUCCESS
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
  TRIAL
  SUSPENDED
}

enum PaymentMethod {
  CARD
  CIB
  D17
  BARIDIMOB
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
  PARTIAL_REFUND
}

enum PaymentGateway {
  STRIPE
  PAYPAL
  CIB
  D17
  BARIDIMOB
}

enum AchievementCategory {
  LEARNING
  ENGAGEMENT
  PERFORMANCE
  SOCIAL
  SPECIAL
}

enum CertificateType {
  COURSE_COMPLETION
  ACHIEVEMENT
  EXAM_PASSED
  PROGRAM_COMPLETION
}

enum ExamSessionStatus {
  PENDING
  STARTED
  COMPLETED
  ABANDONED
  VIOLATION
}

enum ProctorEventType {
  FACE_MISSING
  MULTIPLE_FACES
  OBJECT_DETECTED
  TAB_SWITCH
  SCREEN_SHARE
  AUDIO_CHANGE
  SUSPICIOUS_MOTION
  TIMEOUT
}

enum SecurityEventType {
  LOGIN_ATTEMPT
  FAILED_LOGIN
  SUSPICIOUS_ACTIVITY
  RATE_LIMIT_EXCEEDED
  SQL_INJECTION_ATTEMPT
  XSS_ATTEMPT
  PERMISSION_VIOLATION
  API_KEY_ROTATION
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum BackupType {
  FULL
  INCREMENTAL
  SCHEMA
  DATA
}

enum BackupStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum JobType {
  BACKUP
  CLEANUP
  ANALYTICS
  EMAIL
  NOTIFICATION
  SYNC
}

enum JobStatus {
  ENABLED
  DISABLED
  RUNNING
  FAILED
}

enum JobExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// ==================== CORE SCHEMA ====================

model Base {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  @@map("base")
}

model User {
  id                  String      @id @default(cuid())
  email               String      @unique
  password            String?
  phone               String?
  firstName           String
  lastName            String
  avatar              String?
  role                Role        @default(STUDENT)
  isActive            Boolean     @default(true)
  isVerified          Boolean     @default(false)
  emailVerified       Boolean     @default(false)
  phoneVerified       Boolean     @default(false)
  lastLogin           DateTime?
  preferences         Json?
  twoFactorSecret     String?
  twoFactorEnabled    Boolean     @default(false)
  failedLoginAttempts Int         @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deletedAt           DateTime?

  student          Student?
  teacher          Teacher?
  admin            Admin?
  organizationId   String?
  organization     Organization?  @relation(fields: [organizationId], references: [id])
  subscriptions    Subscription[]
  payments         Payment[]
  deviceTokens     DeviceToken[]
  loginHistory     LoginHistory[]
  auditLogs        AuditLog[]     @relation("UserAudit")
  refreshTokens    RefreshToken[]
  messages         Message[]      @relation("SenderMessages")
  receivedMessages Message[]      @relation("ReceiverMessages")
  forumTopics      ForumTopic[]
  forumReplies     ForumReply[]
  aiChats          AIChat[]
  aiMessages       AIMessage[]
  resourceUploads  Resource[]
  organizationMembers OrganizationMember[]
  questionsCreated   Question[]
  liveChatMessages   ChatMessage[]
  forumLikes         ForumLike[]
  securityLogs       SecurityLog[]
  errorLogs          ErrorLog[]
  @@index([email])
  @@index([role])
  @@index([organizationId])
  @@map("users")
}

model Student {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level                Level     @default(ONE_AS)
  stream               Stream?
  studyHoursPerWeek    Int       @default(10)
  preferredStudyTime   String?
  levelTestScore       Float?
  levelTestCompleted   Boolean   @default(false)
  totalStudyTime       Int       @default(0)
  completedAssignments Int       @default(0)
  averageScore         Float     @default(0)
  streakDays           Int       @default(0)
  lastActiveDate       DateTime?
  xpPoints             Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  weakSubjects     StudentWeakSubject[]
  achievements     StudentAchievement[]
  lessonProgress   LessonProgress[]
  videoProgress    VideoProgress[]
  submissions      Submission[]
  quizAttempts     QuizAttempt[]
  liveAttendances  LiveAttendance[]
  chatMessages     ChatMessage[]
  raisedHands      RaisedHand[]
  learningPaths    LearningPathStudent[]
  classMembers     ClassMember[]
  questionAnswers  QuestionAnswer[]
  openEndedAnswers OpenEndedAnswer[]
  aiRecommendations AIRecommendation[]
  aiLearningPaths   LearningPath[]
  aiAnalyses        AIAnalysis[]
  aiPredictions     AIPrediction[]
  certificates      Certificate[]
  churnPredictions  ChurnPrediction[]
  examSessions      ExamSession[]

  @@index([userId])
  @@index([level, stream])
  @@map("students")
}

model StudentWeakSubject {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  score     Float?
  priority  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId])
  @@map("student_weak_subjects")
}

model Teacher {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification         String?
  certificationFile     String?
  certificationVerified Boolean   @default(false)
  bio                   String?
  rating                Float     @default(0)
  totalStudents         Int       @default(0)
  isAvailable           Boolean   @default(true)
  hourlyRate            Float?
  specialties           TeacherSpecialty[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  liveClasses     LiveClass[]
  assignments     Assignment[]
  quizzes         Quiz[]
  classGroups     ClassGroup[]
  liveChatMessages ChatMessage[]

  @@index([userId])
  @@map("teachers")
}

model TeacherSpecialty {
  id         String   @id @default(cuid())
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  experience Int?
  level      Level?

  @@unique([teacherId, subjectId])
  @@map("teacher_specialties")
}

model Admin {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String[]  @default([])
  lastAction  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@map("admins")
}

model Organization {
  id              String    @id @default(cuid())
  name            String
  nameAr          String
  nameFr          String
  email           String    @unique
  phone           String?
  address         String?
  logo            String?
  isActive        Boolean   @default(true)
  subscriptionEnd DateTime?
  planId          String?
  plan            SubscriptionPlan? @relation(fields: [planId], references: [id])
  settings        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users               User[]
  classGroups         ClassGroup[]
  organizationMembers OrganizationMember[]
  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  joinedAt       DateTime     @default(now())
  @@unique([organizationId, userId])
  @@map("organization_members")
}

model ClassGroup {
  id             String       @id @default(cuid())
  name           String
  description    String?
  teacherId      String
  teacher        Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  level          Level
  stream         Stream?
  subjectId      String?
  subject        Subject?     @relation(fields: [subjectId], references: [id])
  schedule       Json?
  maxStudents    Int          @default(30)
  startDate      DateTime
  endDate        DateTime?
  isActive       Boolean      @default(true)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  members     ClassMember[]
  liveClasses LiveClass[]
  assignments Assignment[]
  quizzes     Quiz[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  @@map("class_groups")
}

model ClassMember {
  id           String     @id @default(cuid())
  classGroupId String
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  joinedAt     DateTime   @default(now())
  leftAt       DateTime?
  isActive     Boolean    @default(true)
  @@unique([classGroupId, studentId])
  @@map("class_members")
}

// ==================== EDUCATION SCHEMA ====================

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  nameAr      String   @unique
  nameFr      String   @unique
  description String?
  icon        String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  parentId    String?
  parent      Subject? @relation("SubjectChildren", fields: [parentId], references: [id])
  children    Subject[] @relation("SubjectChildren")

  levels              LevelSubject[]
  assignments         Assignment[]
  quizzes             Quiz[]
  questions           Question[]
  resources           Resource[]
  weakSubjects        StudentWeakSubject[]
  teacherSpecialties  TeacherSpecialty[]
  forumTopics         ForumTopic[]
  classGroups         ClassGroup[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  @@map("subjects")
}

model LevelSubject {
  id          String   @id @default(cuid())
  level       Level
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  stream      Stream?
  isRequired  Boolean  @default(true)
  coefficient Int      @default(1)
  chapters    Chapter[]
  @@unique([level, subjectId, stream])
  @@map("level_subjects")
}

model Chapter {
  id             String       @id @default(cuid())
  name           String
  nameAr         String
  nameFr         String
  description    String?
  order          Int          @default(0)
  levelSubjectId String
  levelSubject   LevelSubject @relation(fields: [levelSubjectId], references: [id], onDelete: Cascade)
  isActive       Boolean      @default(true)

  lessons     Lesson[]
  assignments Assignment[]
  quizzes     Quiz[]
  questions   Question[]
  resources   Resource[]
  forumTopics ForumTopic[]

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  @@index([levelSubjectId])
  @@map("chapters")
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  titleAr   String
  titleFr   String
  content   String   @db.Text
  contentAr String?  @db.Text
  contentFr String?  @db.Text
  summary   String?  @db.Text
  summaryAr String?  @db.Text
  summaryFr String?  @db.Text
  videoUrl  String?
  videoEmbed String?
  pdfUrl    String?
  audioUrl  String?
  duration  Int?
  order     Int      @default(0)
  isPublished Boolean @default(false)
  isFree    Boolean  @default(false)
  views     Int      @default(0)
  likes     Int      @default(0)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  assignments    Assignment[]
  quizzes        Quiz[]
  lessonProgress LessonProgress[]
  videoProgress  VideoProgress[]
  liveClasses    LiveClass[]
  resources      Resource[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([chapterId])
  @@map("lessons")
}

model LessonProgress {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progress     Float    @default(0)
  timeSpent    Int      @default(0)
  completed    Boolean  @default(false)
  completedAt  DateTime?
  lastAccessed DateTime @default(now())
  @@unique([studentId, lessonId])
  @@index([studentId, lessonId])
  @@map("lesson_progress")
}

model VideoProgress {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  watchTime    Int      @default(0)
  duration     Int
  lastPosition Int      @default(0)
  completed    Boolean  @default(false)
  watchedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([studentId, lessonId])
  @@map("video_progress")
}

model Resource {
  id          String       @id @default(cuid())
  title       String
  titleAr     String?
  titleFr     String?
  description String?      @db.Text
  type        ResourceType
  fileUrl     String
  size        Int?
  mimeType    String?
  uploaderId  String
  uploader    User         @relation(fields: [uploaderId], references: [id])
  subjectId   String?
  subject     Subject?     @relation(fields: [subjectId], references: [id])
  chapterId   String?
  chapter     Chapter?     @relation(fields: [chapterId], references: [id])
  lessonId    String?
  lesson      Lesson?      @relation(fields: [lessonId], references: [id])
  level       Level?
  stream      Stream?
  downloads   Int          @default(0)
  views       Int          @default(0)
  isPublished Boolean      @default(false)
  isFree      Boolean      @default(true)
  isVerified  Boolean      @default(false)
  tags        ResourceTag[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  @@index([subjectId, level])
  @@map("resources")
}

model ResourceTag {
  id        String     @id @default(cuid())
  name      String     @unique
  resources Resource[]
  @@map("resource_tags")
}

// ==================== ASSESSMENT SCHEMA ====================

model Question {
  id            String       @id @default(cuid())
  content       String       @db.Text
  contentAr     String?      @db.Text
  contentFr     String?      @db.Text
  type          QuestionType @default(MULTIPLE_CHOICE)
  difficulty    Difficulty   @default(MEDIUM)
  points        Int          @default(1)
  hints         String?      @db.Text
  explanation   String?      @db.Text
  explanationAr String?      @db.Text
  explanationFr String?      @db.Text
  isActive      Boolean      @default(true)
  isVerified    Boolean      @default(false)
  usageCount    Int          @default(0)
  successRate   Float?
  subjectId     String?
  subject       Subject?     @relation(fields: [subjectId], references: [id])
  chapterId     String?
  chapter       Chapter?     @relation(fields: [chapterId], references: [id])
  createdBy     String?
  createdByUser User?        @relation(fields: [createdBy], references: [id])
  assignmentId  String?
  assignment    Assignment?  @relation(fields: [assignmentId], references: [id])
  quizId        String?
  quiz          Quiz?        @relation(fields: [quizId], references: [id])

  options          QuestionOption[]
  tags             QuestionTag[]
  answers          QuestionAnswer[]
  openEndedAnswers OpenEndedAnswer[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  @@index([subjectId, chapterId])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String   @db.Text
  textAr     String?  @db.Text
  textFr     String?  @db.Text
  isCorrect  Boolean  @default(false)
  order      Int      @default(0)
  @@map("question_options")
}

model QuestionTag {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  questions   Question[]
  @@map("question_tags")
}

model Assignment {
  id           String         @id @default(cuid())
  title        String
  description  String?        @db.Text
  type         AssignmentType @default(PRACTICE)
  difficulty   Difficulty     @default(MEDIUM)
  points       Int            @default(10)
  timeLimit    Int?
  passingScore Int?
  isPublished  Boolean        @default(false)
  isFree       Boolean        @default(false)
  dueDate      DateTime?
  maxAttempts  Int?           @default(1)
  teacherId    String?
  teacher      Teacher?       @relation(fields: [teacherId], references: [id])
  subjectId    String?
  subject      Subject?       @relation(fields: [subjectId], references: [id])
  lessonId     String?
  lesson       Lesson?        @relation(fields: [lessonId], references: [id])
  chapterId    String?
  chapter      Chapter?       @relation(fields: [chapterId], references: [id])
  classGroupId String?
  classGroup   ClassGroup?    @relation(fields: [classGroupId], references: [id])

  questions     Question[]
  submissions   Submission[]
  gradingRubric GradingRubric?

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  @@index([teacherId, subjectId])
  @@map("assignments")
}

model Quiz {
  id               String    @id @default(cuid())
  title            String
  description      String?   @db.Text
  type             QuizType  @default(PRACTICE)
  difficulty       Difficulty @default(MEDIUM)
  timeLimit        Int?
  passingScore     Int?
  isPublished      Boolean   @default(false)
  isFree           Boolean   @default(false)
  isTimed          Boolean   @default(false)
  shuffleQuestions Boolean   @default(false)
  shuffleOptions   Boolean   @default(false)
  showAnswers      Boolean   @default(true)
  points           Int       @default(10)
  maxAttempts      Int?      @default(1)
  teacherId        String?
  teacher          Teacher?  @relation(fields: [teacherId], references: [id])
  subjectId        String?
  subject          Subject?  @relation(fields: [subjectId], references: [id])
  lessonId         String?
  lesson           Lesson?   @relation(fields: [lessonId], references: [id])
  chapterId        String?
  chapter          Chapter?  @relation(fields: [chapterId], references: [id])
  classGroupId     String?
  classGroup       ClassGroup? @relation(fields: [classGroupId], references: [id])

  questions     Question[]
  attempts      QuizAttempt[]
  gradingRubrics GradingRubric[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  @@index([teacherId, subjectId])
  @@map("quizzes")
}

model Submission {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  assignmentId  String?
  assignment    Assignment? @relation(fields: [assignmentId], references: [id])
  quizAttemptId String?
  quizAttempt   QuizAttempt? @relation(fields: [quizAttemptId], references: [id])
  score         Float?
  maxScore      Float
  percentage    Float?
  passed        Boolean?
  feedback      String?   @db.Text
  feedbackAi    String?   @db.Text
  timeTaken     Int?
  attemptNumber Int       @default(1)
  isGraded      Boolean   @default(false)
  isLate        Boolean   @default(false)
  submittedAt   DateTime  @default(now())
  gradedAt      DateTime?
  gradedBy      String?

  answers        QuestionAnswer[]
  gradingRecords GradingRecord[]
  aiGradings     AIGrading[]
  @@index([studentId, assignmentId])
  @@map("submissions")
}

model QuizAttempt {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score         Float
  maxScore      Float
  percentage    Float
  passed        Boolean?
  timeTaken     Int?
  attemptNumber Int       @default(1)
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  answers     QuestionAnswer[]
  submissions Submission[]
  @@index([studentId, quizId])
  @@map("quiz_attempts")
}

model QuestionAnswer {
  id            String    @id @default(cuid())
  questionId    String
  question      Question  @relation(fields: [questionId], references: [id])
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answer        String?   @db.Text
  isCorrect     Boolean?
  pointsEarned  Float?
  feedback      String?   @db.Text
  quizAttemptId String?
  quizAttempt   QuizAttempt? @relation(fields: [quizAttemptId], references: [id])
  submissionId  String?
  submission    Submission? @relation(fields: [submissionId], references: [id])
  createdAt     DateTime  @default(now())
  @@index([studentId, questionId])
  @@map("question_answers")
}

model OpenEndedAnswer {
  id              String    @id @default(cuid())
  questionId      String
  question        Question  @relation(fields: [questionId], references: [id])
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answer          String    @db.Text
  aiGrading       Json?
  teacherGrading  Json?
  finalGrade      Float?
  feedback        String?   @db.Text
  isAIGraded      Boolean   @default(false)
  isTeacherGraded Boolean   @default(false)
  submittedAt     DateTime  @default(now())
  gradedAt        DateTime?
  @@map("open_ended_answers")
}

model GradingRubric {
  id           String    @id @default(cuid())
  name         String
  description  String?   @db.Text
  criteria     Json
  assignmentId String?   @unique
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])
  quizId       String?
  quiz         Quiz?     @relation(fields: [quizId], references: [id])
  isDefault    Boolean   @default(false)
